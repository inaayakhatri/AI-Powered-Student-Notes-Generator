QWidget {
    background: #f5f5f5;
    color: #222;
    font-family: Arial, sans-serif;
}
QPushButton {
    background: #2980b9;
    color: white;
    border-radius: 5px;
    padding: 8px;
}
QPushButton:hover {
    background: #3498db;
}
QLineEdit, QComboBox {
    background: white;
    border: 1px solid #ccc;
    border-radius: 4px;
    padding: 6px;
}
QLabel {
    font-size: 14px;
}
